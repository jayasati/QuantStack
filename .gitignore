# MkDocs build output (built by CI, never committed)
site/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# CatBoost training logs (written to CWD by CatBoostClassifier.fit())
catboost_info/

# Secrets — never commit credentials
.env

# Runtime artifacts (directories tracked via .gitkeep only)
logs/*
!logs/.gitkeep
data/*
!data/.gitkeep
models/*
!models/.gitkeep
feature_store/*
!feature_store/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
